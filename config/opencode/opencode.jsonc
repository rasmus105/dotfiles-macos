{
  "$schema": "https://opencode.ai/config.json",

  "model": "mlx-gemma4/mlx-community/gemma-4-26B-A4B-it-qat-4bit",

  "provider": {
    "mlx-gemma4": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX Gemma 4 26B MTP",

      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "not-needed"
      },

      "models": {
        "mlx-community/gemma-4-26B-A4B-it-qat-4bit": {
          "name": "Gemma 4 26B-A4B QAT 4-bit + MTP",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  }
}
