#!/usr/bin/env zsh

# Environment variables and path setup.

# ==============================================================================
# Defaults
# ==============================================================================

export EDITOR="nvim"
export MANPAGER="nvim +Man!"
export TERM="xterm-256color"

# ==============================================================================
# Tool Homes
# ==============================================================================

export BUN_INSTALL="$HOME/.bun"

# ==============================================================================
# Paths
# ==============================================================================

typeset -U path
path=(
  "$HOME/.cargo/bin"
  "$HOME/.local/bin"
  "$BUN_INSTALL/bin"
  $path
)
export PATH
